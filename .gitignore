# OS
.DS_Store

# Logs and temp files
logs/
*.log
.pids/
.checkpoints/

# Compiled binaries (keep source, ignore large binaries)
*.bin
*.o
*.a
*.tmp
*.dSYM/
build/
build-*/
build_*/
builds/
CMakeFiles/
bugs/**/poc/poc_*
bugs/**/poc/radiourl_oob*

# But keep the debug binary for PoC
!bugs/*/poc/poc_vulnerable_debug
!bugs/**/poc/*.c
!bugs/**/poc/*.cc
!bugs/**/poc/*.cpp
!bugs/**/poc/*.cxx
!bugs/**/poc/*.h
!bugs/**/poc/*.hpp
!bugs/**/poc/*.md
!bugs/**/poc/*.proto
!bugs/**/poc/*.py
!bugs/**/poc/*.sh
!bugs/**/poc/*.txt

# Findings (generated)
findings/

# Reports (generated)
reports/

# Targets (cloned repos - too large)
targets/

# Local review scratch space
tmp_review/
tmp_tools/
